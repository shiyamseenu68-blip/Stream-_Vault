{
  "buildCommand": "pnpm --filter @workspace/streamvault run build && node scripts/copy-dist.js",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!assets/|favicon\\.svg|robots\\.txt|api).*)",
      "destination": "/index.html"
    }
  ]
}
