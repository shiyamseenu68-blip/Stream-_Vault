{
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": "vite",
  "outputDirectory": "dist",
  "rootDirectory": "artifacts/streamvault",
  "rewrites": [
    {
      "source": "/((?!assets/|favicon\\.svg|robots\\.txt).*)",
      "destination": "/index.html"
    }
  ]
}
