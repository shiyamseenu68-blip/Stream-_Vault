{
  "buildCommand": "pnpm --filter @workspace/streamvault run build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "outputDirectory": "artifacts/streamvault/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!assets/|favicon\\.svg|robots\\.txt|api).*)",
      "destination": "/index.html"
    }
  ]
}
